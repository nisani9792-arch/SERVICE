# העתק ל-.env מקומי (לא ל-Git). רשימה מלאה ל-Render: docs/RENDER-ENV-HE.md

# === חובה ===
DATABASE_URL=
GATE_ACCESS_CODE=JUSIC
GOOGLE_GEMINI_API_KEY=

# אופציונלי — ניתוב מודלים (ברירת מחדל: flash לסיווג מהיר, pro לסיווג עמוק)
# GEMINI_MODEL_FLASH=gemini-1.5-flash
# GEMINI_MODEL_PRO=gemini-1.5-pro

EMAIL_INGEST_SECRET=
EMAIL_OUTBOUND_SECRET=

# === מייל ===
EMAIL_FROM=EDITOR@JUSIC.CO
EMAIL_FROM_NAME=Jusic
EMAIL_REPLY_OPENING=היי. בהמשך לפנייתך לאפליקציית ג'וזיק:
EMAIL_REPLY_CLOSING=בברכה, ישי מג'וזיק.

EMAIL_INGEST_PROVIDER=imap
EMAIL_IMAP_USER=EDITOR@JUSIC.CO
EMAIL_IMAP_APP_PASSWORD=
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_MAILBOX=INBOX

EMAIL_REPLY_PROVIDER=gmail_api
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

EMAIL_SMTP_USER=EDITOR@JUSIC.CO
EMAIL_SMTP_APP_PASSWORD=
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_TIMEOUT_MS=25000

EMAIL_INGEST_SOURCE_TAG=EDITOR
EMAIL_INGEST_LOOKBACK_DAYS=14
EMAIL_INGEST_MAX_MESSAGES=50
EMAIL_INGEST_TIMEOUT_MS=90000
EMAIL_INGEST_ATTACHMENTS=true
EMAIL_ATTACHMENT_MAX_BYTES=8388608
EMAIL_ATTACHMENT_MAX_COUNT=8
EMAIL_ATTACHMENT_ALLOW=image,video

BACKUP_RETENTION_COUNT=12
BACKUP_INCLUDE_ATTACHMENTS=true
BACKUP_SECRET=
BACKUP_URL=
DATABASE_BACKUP_URL=

# cron בלבד (לא על web)
EMAIL_INGEST_URL=
EMAIL_OUTBOUND_URL=
