DATABASE_URL=
GOOGLE_GEMINI_API_KEY=
GEMINI_API_KEY=
EMAIL_INGEST_SECRET=
EMAIL_IMAP_USER=EDITOR@JUSIC.CO
EMAIL_IMAP_APP_PASSWORD=
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_MAILBOX=INBOX
EMAIL_SMTP_USER=EDITOR@JUSIC.CO
EMAIL_SMTP_APP_PASSWORD=
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_TIMEOUT_MS=25000
# Optional: try implicit SSL on 465 after 587 (on Render this is tried automatically)
EMAIL_SMTP_TRY_465=false
# Render blocks outbound SMTP — use Resend (HTTPS) for replies in production:
RESEND_API_KEY=
EMAIL_FROM=EDITOR@JUSIC.CO
# auto | resend | smtp
EMAIL_REPLY_PROVIDER=auto
EMAIL_INGEST_SOURCE_TAG=EDITOR
EMAIL_INGEST_LOOKBACK_DAYS=14
EMAIL_INGEST_MAX_MESSAGES=25
EMAIL_INGEST_TIMEOUT_MS=45000
# Incoming email attachments (images/videos saved with the ticket)
EMAIL_INGEST_ATTACHMENTS=true
EMAIL_ATTACHMENT_MAX_BYTES=8388608
EMAIL_ATTACHMENT_MAX_COUNT=8
EMAIL_ATTACHMENT_ALLOW=image,video
EMAIL_INGEST_URL=
