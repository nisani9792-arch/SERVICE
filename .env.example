DATABASE_URL=
# Lock screen code (default JUSIC). Must match on Render if you override it.
GATE_ACCESS_CODE=JUSIC
GOOGLE_GEMINI_API_KEY=
GEMINI_API_KEY=
EMAIL_INGEST_SECRET=
EMAIL_IMAP_USER=EDITOR@JUSIC.CO
EMAIL_IMAP_APP_PASSWORD=
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_MAILBOX=INBOX
EMAIL_SMTP_USER=EDITOR@JUSIC.CO
EMAIL_SMTP_APP_PASSWORD=
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_TIMEOUT_MS=25000
# Optional: try implicit SSL on 465 after 587 (on Render this is tried automatically)
EMAIL_SMTP_TRY_465=false
# Customer replies via Resend (required on Render — SMTP is blocked):
RESEND_API_KEY=
EMAIL_FROM=EDITOR@JUSIC.CO
EMAIL_FROM_NAME=Jusic
# resend | smtp | auto  (use resend in production)
EMAIL_REPLY_PROVIDER=resend
EMAIL_INGEST_SOURCE_TAG=EDITOR
EMAIL_INGEST_LOOKBACK_DAYS=14
EMAIL_INGEST_MAX_MESSAGES=25
EMAIL_INGEST_TIMEOUT_MS=45000
# Incoming email attachments (images/videos saved with the ticket)
EMAIL_INGEST_ATTACHMENTS=true
EMAIL_ATTACHMENT_MAX_BYTES=8388608
EMAIL_ATTACHMENT_MAX_COUNT=8
EMAIL_ATTACHMENT_ALLOW=image,video
EMAIL_INGEST_URL=
# Outbound queue cron (Render: jusic-email-outbound)
EMAIL_OUTBOUND_URL=
EMAIL_OUTBOUND_SECRET=
# Automatic DB backups (cron every 3 days → folder "backups" in backup_snapshots table)
BACKUP_SECRET=
BACKUP_URL=
# Optional: separate Neon DB URL — snapshots stored only there (recommended for disaster recovery)
DATABASE_BACKUP_URL=
BACKUP_RETENTION_COUNT=12
BACKUP_INCLUDE_ATTACHMENTS=true
